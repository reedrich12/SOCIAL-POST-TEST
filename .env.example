# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Cloudflare R2 Access (S3 Compatible API)
R2_ACCOUNT_ID="your_account_id"
R2_ACCESS_KEY_ID="your_access_key"
R2_SECRET_ACCESS_KEY="your_secret_key"
R2_BUCKET_NAME="docktok-assets"
# Optional: R2 prefix the music scraper fills with trending tracks; the
# orchestrator picks one at random per job (default: music/)
# R2_MUSIC_PREFIX="music/"

# OpenAI API for dynamic captions
OPENAI_API_KEY="sk-..."
# Optional: caption model (default: gpt-4o-mini)
# OPENAI_MODEL="gpt-4o-mini"

# Zernio API for cross-platform publishing (Instagram, TikTok)
ZERNIO_API_KEY="your_zernio_key"
# Optional: override the Zernio API base URL (default: https://zernio.com/api/v1)
# ZERNIO_API_URL="https://zernio.com/api/v1"
# Optional: pin specific account IDs (otherwise auto-discovered via GET /accounts)
# ZERNIO_TIKTOK_ACCOUNT_ID=""
# ZERNIO_INSTAGRAM_ACCOUNT_ID=""
# Optional: TikTok privacy level for published videos (default: PUBLIC_TO_EVERYONE).
# Must be one of the values your TikTok account's creator-info allows.
# ZERNIO_TIKTOK_PRIVACY="PUBLIC_TO_EVERYONE"

# Optional: local background-music fallback dir, used only when the R2 music
# prefix is empty (default: ./assets/music)
# MUSIC_DIR="./assets/music"

# Optional: format output as vertical 9:16 (Reel/TikTok) by default. Can also be
# set per request via the dashboard toggle or the trigger API's "vertical" field.
# FORCE_VERTICAL="true"

# --- Trending-audio scraper (scraper/), optional ---
# SCRAPER_SOURCE="ytdlp"            # ytdlp | rapidapi
# SCRAPER_MAX_TRACKS="50"
# RAPIDAPI_KEY=""
# RAPIDAPI_HOST=""
# RAPIDAPI_TRENDING_URL=""
